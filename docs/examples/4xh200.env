# Non-interactive config for a 4×H200 NVLink single-node host.
# Source as MLPERF_CONFIG_FILE to drive mlperf.sh end-to-end without prompts.
#
# Usage:
#     MLPERF_CONFIG_FILE=docs/examples/4xh200.env bash mlperf.sh
#
# Every variable below corresponds to a Step-N prompt default. `MLPERF_AUTO_YES=1`
# is set automatically when a config file is sourced, so the driver will pick
# default at every prompt — edit values here to drive its decisions.

# ----------------------------------------------------------------------
# Step 0/1 — workload + repo
# ----------------------------------------------------------------------
# We pick the first workload (alphabetical) by default. To force llama31_8b,
# rename manifests or export WL_OVERRIDE (feature, not yet wired).
# Repo location must already exist; clone separately.
#
# export REPO_DIR=/scratch/training_results_v5.1

# ----------------------------------------------------------------------
# Step 2 — container source
# ----------------------------------------------------------------------
# Pick "docker: build locally" (option 1) — H200 requires a fresh build with
# NVTE_CUDA_ARCHS containing sm_90. The manifest's Dockerfile patch makes
# this automatic when you accept the "Patch Dockerfile" prompt; AUTO_YES=1
# accepts it.
#
# Local image tag.
export IMAGE="${IMAGE:-mlperf-nvidia:llama31_8b-pyt-sm90}"

# ----------------------------------------------------------------------
# Step 3 — dataset
# ----------------------------------------------------------------------
export DATADIR="${DATADIR:-/scratch/mlperf_data}"

# ----------------------------------------------------------------------
# Step 4 — config
# ----------------------------------------------------------------------
# Option 1 = first config in the picker; for llama31_8b this is the DGXB200.
# Custom smoke is the last option. For a safe single-node H200 smoke, set:
#
# export MLPERF_PICK_CUSTOM_SMOKE=1   # (informational; AUTO_YES picks #1)

# ----------------------------------------------------------------------
# Step 5 — runtime
# ----------------------------------------------------------------------
export LOGDIR="${LOGDIR:-/scratch/mlperf_logs}"
export SEED=42
export NGPU=4
# Limit docker to 4 H200s if the node has more:
# export CUDA_VISIBLE_DEVICES=0,1,2,3

# Custom smoke prompts (honoured when IS_CUSTOM=1).
export MAX_STEPS=3
export OVERWRITTEN_NUM_LAYERS=2

# ----------------------------------------------------------------------
# Step 6 — launcher
# ----------------------------------------------------------------------
# On a single node without Slurm, the first non-disabled launcher offered
# is "docker smoke" (for custom config) or "docker run" (for full config).
# AUTO_YES selects option 1 at every prompt — set CUDA_VISIBLE_DEVICES above
# to constrain to the four H200s if the host has more GPUs.

# Runtime wall time (MINUTES for docker/bare).
export WALLTIME=60

# Optional webhook for completion notification.
# export MLPERF_NOTIFY_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ
