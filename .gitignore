.vscode/
.idea/
*.swp
.DS_Store
Thumbs.db

# Pytest / build artefacts (if the script grows test coverage)
__pycache__/
*.pyc
.pytest_cache/
docs/DOCKER_HUB_DESCRIPTION.md
